    "shipping": {
      "1": {
        "title": "Shipping & Delivery",
        "desc": "We offer free standard shipping on all orders over 100.000đ. Express shipping available for faster delivery. All orders are processed within 1-2 business days. Delivery times vary by location but typically arrive within 3-7 business days for standard shipping."
      },
      "2": {
        "title": "Returns & Exchanges",
        "desc": "We accept returns within 30 days of purchase. Items must be unworn, unwashed, and in original condition with tags attached. Free return shipping for exchanges. Refunds are processed within 5-7 business days after we receive your return."
      },
      "3": {
        "title": "Size Guide",
        "desc": "Please refer to our detailed size chart for accurate measurements. We recommend measuring yourself and comparing with our size guide before ordering. If you're between sizes, we suggest sizing up for a more comfortable fit. Contact our customer service for personalized sizing advice."
      },
      "4": {
        "title": "Care Instructions",
        "desc": "To maintain the quality of your garment, follow the care label instructions. Most items can be machine washed cold with like colors. Tumble dry low or hang to dry. Iron on low heat if needed. For delicate fabrics, dry cleaning is recommended."
      }
    },
    "related": {
      "title": "Related Products",
      "desc": "Explore complementary options that enhance your experience. Discover related products curated just for you."
    }
  },
